{
  "name": "openweek",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:gen": "npx @better-auth/cli@latest generate --config auth.config.ts --output server/db/schema/auth.ts -y",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^3.0.0",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@googleapis/calendar": "^15.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.3.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "better-auth": "^1.6.20",
    "daisyui": "^5.5.23",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fractional-indexing-jittered": "^1.0.0",
    "google-auth-library": "^10.9.0",
    "ical.js": "^2.2.1",
    "nuxt": "^4.4.8",
    "pg": "^8.22.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "tsdav": "^2.2.2",
    "uuidv7": "^1.2.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.6",
    "playwright-core": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "version": "0.1.0"
}
