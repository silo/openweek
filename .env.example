# Openweek environment — copy to .env and fill in. All vars are Zod-validated at
# boot (server/utils/runtime-config.ts); a missing/invalid value fails fast.
# See docs/self-hosting.md for the full contract.

# --- Required ---

# Postgres connection. In the compose stack the host is the service name `db`.
DATABASE_URL=postgres://openweek:openweek@localhost:5432/openweek

# Signs sessions. Generate: openssl rand -base64 32
# Rotating this logs everyone out.
BETTER_AUTH_SECRET=dev-only-change-me-openssl-rand-base64-32

# Public origin — used for cookies, OAuth callbacks, and trustedOrigins.
BETTER_AUTH_URL=http://localhost:3000

# Encrypts CalDAV/Google calendar secrets. Must be base64 of EXACTLY 32 bytes.
# Generate: openssl rand -base64 32  (distinct from BETTER_AUTH_SECRET)
OPENWEEK_ENCRYPTION_KEY=ZGV2LW9ubHktMzItYnl0ZS1rZXktY2hhbmdlLW1lISE=

# Enables secure cookies etc. Use `production` when deployed.
NODE_ENV=development

# --- Optional ---

# Google login and/or Google calendar connect. App runs fine without them.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Calendar poll interval (Phase 5).
OPENWEEK_SYNC_INTERVAL=10m

# Host port for the compose `db` service. Override only if 5432 is already taken
# on your machine (the in-container connection always uses 5432).
# OPENWEEK_DB_PORT=5432
